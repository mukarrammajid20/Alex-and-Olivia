# Google Maps API key for embedded venue maps
GOOGLE_MAPS_API_KEY=

# Public site URL for Open Graph image absolute paths
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL connection string for RSVP storage (optional — falls back to JSON file)
DATABASE_URL=

# Admin panel password
ADMIN_PASSWORD=change-me-in-production

# Session encryption secret (min 32 characters; defaults to ADMIN_PASSWORD in dev)
SESSION_SECRET=
